  <conditions>
    <!-- Compiler Conditions -->
    <condition id="Compiler ARMCC">
      <require Tcompiler="ARMCC"/>
    </condition>


    <!-- Device Conditions -->
    <condition id="GD32F50x">
      <description>GigaDevice GD32F50x Devices</description>
      <require Dvendor="GigaDevice:123" Dname="GD32F50[235]*"/>
      <require Cclass="Device" Cgroup="Startup" />
    </condition>

    <!-- Device + CMSIS Conditions -->
    <condition id="GD32F50x CMSIS">
      <description>GigaDevice GD32F50x Devices and CMSIS-CORE</description>
      <accept condition="GD32F50x" />
      <require Cclass="CMSIS" Cgroup="CORE" />
      <require Cclass="Device" Cgroup="GD32F50x_libopt" />
      <require Cclass="Device" Cgroup="GD32F50x_StdPeripherals" Csub="RCU" />
      <require Cclass="Device" Cgroup="GD32F50x_StdPeripherals" Csub="PMU" />
    </condition>

    <!-- GD32F50x STDPERIPHERALS RCU Conditions -->
    <condition id="GD32F50x STDPERIPHERALS RCU">
      <description>GigaDevice GD32F50x Standard Peripherals Drivers with RCU</description>
      <require condition="GD32F50x CMSIS" />
      <require Cclass="Device" Cgroup="GD32F50x_StdPeripherals" Csub="RCU" />
    </condition>

    <!-- GD32F50x STDPERIPHERALS MISC Conditions -->
    <condition id="GD32F50x STDPERIPHERALS MISC">
      <description>GigaDevice GD32F50x Standard Peripherals Drivers with MISC</description>
      <require condition="GD32F50x CMSIS" />
      <require Cclass="Device" Cgroup="GD32F50x_StdPeripherals" Csub="MISC" />
    </condition>

    <!-- GD32F50x STDPERIPHERALS EVAL Conditions -->
    <condition id="GD32F50x STDPERIPHERALS EVAL">
      <description>GigaDevice GD32F50x Standard Peripherals Drivers with EVAL</description>
      <require condition="GD32F50x CMSIS" />
      <require Cclass="Device" Cgroup="GD32F50x_StdPeripherals" Csub="GPIO" />
      <require Cclass="Device" Cgroup="GD32F50x_StdPeripherals" Csub="EXTI" />
      <require Cclass="Device" Cgroup="GD32F50x_StdPeripherals" Csub="USART" />
    </condition>

  </conditions>
  
  <components>
    <!-- GD32F50x_StdPeripherals -->
    <component Cclass="Device" Cgroup="GD32F50x_StdPeripherals" Csub="ADC" Cversion="1.0.0" condition="GD32F50x STDPERIPHERALS RCU">
      <description>Analog-to-digital converter (ADC) driver for GD32F50x Devices</description>
      <RTE_Components_h>
        #define RTE_DEVICE_STDPERIPHERALS_ADC
      </RTE_Components_h>
      <files>
        <!-- ADC flie -->
        <file category="header" name="Device/Firmware/Peripherals/inc/gd32f50x_adc.h" />
        <file category="source" name="Device/Firmware/Peripherals/src/gd32f50x_adc.c" attr="config" version="1.0.0" />
      </files>
    </component>

    <component Cclass="Device" Cgroup="GD32F50x_StdPeripherals" Csub="BKP" Cversion="1.0.0" condition="GD32F50x STDPERIPHERALS RCU">
      <description>Backup registers (BKP) driver for GD32F50x Devices</description>
      <RTE_Components_h>
        #define RTE_DEVICE_STDPERIPHERALS_BKP
      </RTE_Components_h>
      <files>
